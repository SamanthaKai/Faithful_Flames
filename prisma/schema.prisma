generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  favoriteVerse String?
  bio           String?
  role          Role         @default(USER)
  createdAt     DateTime     @default(now())

  accounts                 Account[]
  sessions                 Session[]
  testimonies              Testimony[]
  reflections              Reflection[]
  forumPosts               ForumPost[]
  forumReplies             ForumReply[]
  prayerRecords            PrayerRecord[]
  journalEntries           JournalEntry[]
  accountabilityRequest    AccountabilityRequest? @relation("AccountabilityUser")
  accountabilityPartnerFor AccountabilityRequest[] @relation("AccountabilityPartner")
  comments                 Comment[]
  likes                    Like[]
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Verse {
  id         String   @id @default(cuid())
  reference  String
  text       String   @db.Text
  reflection String   @db.Text
  tags       String[]
  isDaily    Boolean  @default(false)
  createdAt  DateTime @default(now())

  reflections Reflection[]
}

model Article {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  category    String
  publishedAt DateTime @default(now())
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Devotion {
  id                 String   @id @default(cuid())
  title              String
  scripture          String
  teaching           String   @db.Text
  prayerPoint        String   @db.Text
  reflectionQuestion String
  publishedAt        DateTime @default(now())
  isPublished        Boolean  @default(false)
  createdAt          DateTime @default(now())
}

model Testimony {
  id          String   @id @default(cuid())
  userId      String
  content     String   @db.Text
  isAnonymous Boolean  @default(false)
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reflection {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  mood      String?
  verseId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  verse Verse? @relation(fields: [verseId], references: [id])
}

model ForumPost {
  id        String     @id @default(cuid())
  userId    String
  title     String
  content   String     @db.Text
  topic     ForumTopic
  isFlagged Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies       ForumReply[]
  prayerRecords PrayerRecord[]
}

model PrayerRecord {
  id        String    @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime  @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

enum ForumTopic {
  PRAYER_REQUESTS
  BIBLE_QUESTIONS
  ACCOUNTABILITY
  TESTIMONIES
}

model ForumReply {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String   @db.Text
  isFlagged Boolean  @default(false)
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post     ForumPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   ForumReply?  @relation("ReplyToReply", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children ForumReply[] @relation("ReplyToReply")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
}

enum JournalStatus {
  BELIEVING
  ANSWERED
}

model JournalEntry {
  id        String        @id @default(cuid())
  userId    String
  title     String
  content   String        @db.Text
  status    JournalStatus @default(BELIEVING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AccountabilityFocus {
  BIBLE_READING
  PRAYER
  FASTING
  PURITY
  WORSHIP
  OTHER
}

enum CheckInFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
}

enum RequestStatus {
  PENDING
  MATCHED
}

model AccountabilityRequest {
  id            String              @id @default(cuid())
  userId        String              @unique
  focus         AccountabilityFocus
  frequency     CheckInFrequency
  notes         String?             @db.Text
  status        RequestStatus       @default(PENDING)
  partnerId     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user    User  @relation("AccountabilityUser", fields: [userId], references: [id], onDelete: Cascade)
  partner User? @relation("AccountabilityPartner", fields: [partnerId], references: [id], onDelete: SetNull)
}

enum ContentType {
  VERSE
  ARTICLE
  DEVOTION
  TESTIMONY
  FORUM_POST
}

model Comment {
  id          String      @id @default(cuid())
  userId      String
  content     String      @db.Text
  contentType ContentType
  contentId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Like {
  id          String      @id @default(cuid())
  userId      String
  contentType ContentType
  contentId   String
  createdAt   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentType, contentId])
}
